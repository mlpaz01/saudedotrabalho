          ORDER BY started DESC
          LIMIT 12
        `));
        const rows: any[] = (r[0] ?? r) as any[];
        return (Array.isArray(rows) ? rows : []).map((row: any) => ({
          moduleId: Number(row.id), title: String(row.title),

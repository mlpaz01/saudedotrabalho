# Normaliza quebras de linha: texto sempre LF no repositório.
# Evita divergência de hash entre Windows (CRLF) e Linux/VPS (LF).
* text=auto eol=lf

# Binários — nunca normalizar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.pdf binary
*.zip binary
*.gz binary
*.bundle binary

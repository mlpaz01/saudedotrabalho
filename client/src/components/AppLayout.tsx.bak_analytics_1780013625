          <div className="flex-1 min-w-0">
            <p className="text-sidebar-foreground text-sm font-medium truncate">{user?.name ?? "Usuário"}</p>
            <p className="text-sidebar-foreground/60 text-xs truncate">{user?.email}</p>
          </div>
        </div>
        {isAdmin && (
          <span className="mt-2 inline-block text-xs px-2 py-0.5 rounded-full bg-sidebar-primary/20 text-sidebar-primary font-medium">
            {user?.role === "admin_global" ? "Admin Global" : user?.role === "company_admin" ? "Admin Empresa" : user?.role === "admin" ? "Administrador" : "RH"}
          </span>
        )}
      </div>

      {/* Navigation */}
